MONGODB_URI=mongodb://127.0.0.1:27017/ewc_erp
JWT_SECRET=change-this-secret
PORT=5000
NODE_ENV=development

# Comma-separated browser origins allowed for CORS (required for split deployments)
# Include every URL where the React app is opened (scheme + host + port, no trailing slash)
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173,https://ewc-erp.onrender.com

# Optional extra origins (custom domains, second Render static site, etc.)
# CORS_ORIGINS=https://my-shop.example.com
