# Vite — API base (host or path). See src/config/api.ts
#
# Local backend:
VITE_API_URL=http://localhost:5000
#
# Production API on another host (split deployment):
# VITE_API_URL=https://ewc-erp.onrender.com
#
# Monolith on Render (UI + API same service): leave VITE_API_URL unset in production
# — the build auto-uses same-origin /api
